{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build --webpack",
  "installCommand": "bun install",
  "devCommand": "next dev",
  "regions": ["bom1"],
  "functions": {
    "src/app/**/*": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/models/(.*).glb",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "model/gltf-binary"
        }
      ]
    }
  ]
}
